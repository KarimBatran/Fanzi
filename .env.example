# Copy this file to .env and fill in your real values. Never commit .env.

# Get this from @BotFather on Telegram (/newbot).
TELEGRAM_BOT_TOKEN=

# Optional — defaults shown.
DATABASE_PATH=fanzi.db
CHECK_INTERVAL_MINUTES=60

# Your own Telegram user ID (message @userinfobot to get it). Restricts
# /checkall so it can't be abused if the bot is ever shared.
ADMIN_TELEGRAM_ID=

# --- Deal listener (listener/watcher.py) ---
# Get these from https://my.telegram.org -> API development tools.
TELETHON_API_ID=
TELETHON_API_HASH=
# Session file name; a fanzi_listener.session file will be created alongside it.
TELETHON_SESSION_NAME=fanzi_listener
# Comma-separated public channel usernames (no @), e.g. ba3bou3_deals,deals_eg
DEAL_CHANNELS=
# From https://aistudio.google.com/apikey (free tier) — primary AI provider.
GEMINI_API_KEY=
# From https://console.groq.com/keys (free tier) — automatic fallback when
# Gemini is unavailable/quota-exhausted. Leave empty to run Gemini-only.
GROQ_API_KEY=
# Minimum deal_quality to forward/track: good (default) or great
MIN_DEAL_QUALITY=good

# --- Gemini quota management (keeps usage within the free tier) ---
# Max Gemini calls per minute.
RATE_LIMIT_PER_MIN=12
# Max Gemini calls per day; resets at local midnight.
DAILY_ANALYSIS_CAP=1400
# Posts with a detected discount below this % skip AI analysis entirely
# (treated as a low-value deal without spending quota on either provider).
MIN_DISCOUNT_FOR_ANALYSIS=10
# How long (hours) the same product from the same channel is suppressed as
# a duplicate before it can be re-analyzed/re-forwarded.
DUPLICATE_WINDOW_HOURS=24

# --- AI provider retry/circuit-breaker policy (shared by Gemini and Groq) ---
AI_RETRY_COUNT=3
AI_RETRY_INITIAL_BACKOFF_SECONDS=1
AI_RETRY_MAX_BACKOFF_SECONDS=4
# Consecutive transient failures before a provider is marked unhealthy.
AI_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# How long an unhealthy provider is skipped before a single probe request.
AI_CIRCUIT_BREAKER_COOLDOWN_MINUTES=15
